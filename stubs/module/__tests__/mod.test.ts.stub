import { describe, it, expect, vi } from 'vitest'
import { renderHook } from '@testing-library/react'
import { http, HttpResponse } from 'msw'
import { server } from '@/test/setup'
import { createWrapper } from '@/test/providers'
import { use{{EntityName}}s } from '../hooks'

describe('{{ModuleName}}', () => {
  describe('Hooks', () => {
    it('use{{EntityName}}s returns paginated data', async () => {
      server.use(
        http.get('*/api/{{entitiesName}}', () =>
          HttpResponse.json({
            data: [{ id: '1', name: 'Test', status: 'active', created_at: '2024-01-01', updated_at: '2024-01-01' }],
            meta: { current_page: 1, last_page: 1, per_page: 15, total: 1 },
          })
        )
      )

      const { result } = renderHook(() => use{{EntityName}}s({ page: 1, per_page: 15 }), {
        wrapper: createWrapper(),
      })

      await vi.waitFor(() => expect(result.current.isSuccess).toBe(true))
      expect(result.current.data?.data).toHaveLength(1)
    })

    // TODO: Test remaining hooks with MSW
    it.todo('use{{EntityName}} returns single entity')
    it.todo('useCreate{{EntityName}} invalidates list on success')
    it.todo('useUpdate{{EntityName}} invalidates list and detail on success')
  })
})
